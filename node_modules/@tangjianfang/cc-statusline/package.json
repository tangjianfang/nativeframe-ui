{
  "name": "@tangjianfang/cc-statusline",
  "version": "1.0.2",
  "description": "Custom status line for Claude Code: shows model, output TPS, token/cost totals, git branch and context usage, plus an opt-in auto-continue loop and a pricing updater",
  "main": "statusline.js",
  "bin": {
    "cc-statusline": "statusline.js",
    "loopctl": "loopctl.js",
    "pricing-updater": "pricing-updater.js"
  },
  "files": [
    "statusline.js",
    "loopctl.js",
    "pricing-updater.js",
    "pricing.json",
    "scripts/postinstall.js",
    "install.bat",
    "install-loopctl.bat",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check statusline.js && node --check loopctl.js && node --check pricing-updater.js && node --check scripts/postinstall.js",
    "install": "node statusline.js --install && node loopctl.js --install",
    "install-statusline": "node statusline.js --install",
    "install-loopctl": "node loopctl.js --install",
    "update-pricing": "node pricing-updater.js",
    "pricing:list": "node pricing-updater.js --list",
    "presets": "node loopctl.js presets",
    "demo": "node -e \"process.stdout.write('{}')\" | node statusline.js",
    "demo:subagent": "node -e \"process.stdout.write(JSON.stringify({tasks:[{id:'t1',name:'Explore',tokenCount:100,startTime:'2026-01-01T00:00:00Z'}]}))\" | node statusline.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "statusline",
    "status-line",
    "cli",
    "terminal",
    "cost",
    "tokens",
    "auto-continue",
    "agentic-loop",
    "stop-hook",
    "claude-hooks",
    "cost-tracking",
    "token-counter",
    "tps",
    "pricing",
    "litellm",
    "rate-limit"
  ],
  "engines": {
    "node": ">=16"
  },
  "license": "MIT",
  "author": "cc-statusline contributors",
  "homepage": "https://github.com/tangjianfang/claudecode-statusline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tangjianfang/claudecode-statusline.git"
  },
  "bugs": {
    "url": "https://github.com/tangjianfang/claudecode-statusline/issues"
  },
  "dependencies": {
    "@tangjianfang/cc-statusline": "^1.0.1"
  }
}
