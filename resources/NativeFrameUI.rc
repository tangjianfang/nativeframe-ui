#include "NativeFrameUIResource.h"

#include <windows.h>
#include <commctrl.h>

LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

STRINGTABLE
BEGIN
    IDS_NFUI_APP_TITLE "NativeFrame UI"
END

IDI_NFUI_APP ICON "NativeFrameUI.ico"
IDB_NFUI_MARK BITMAP "NativeFrameUI.bmp"

IDM_NFUI_MAIN MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit", IDM_NFUI_EXIT
    END
END

IDD_NFUI_ABOUT DIALOGEX 0, 0, 320, 130
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About NativeFrame UI"
FONT 9, "Segoe UI"
BEGIN
    // CP23: title + body + build labels are themed by gallery_dialog_proc
    // (palette text colour + Segoe UI semibold/regular/muted). The dialog
    // is sized to host a 14pt title and a multi-line body without truncating.
    LTEXT "NativeFrame UI", IDC_NFUI_ABOUT_TITLE, 14, 12, 290, 20
    LTEXT "Pure Win32 C++20 static UI library. Native HWND-centered controls, command routing, and DPI-aware layout — no MFC, ATL/WTL, or BCG.", IDC_NFUI_ABOUT_BODY, 14, 38, 290, 50
    LTEXT "Build: explicit .rc, palette-injected fonts, ComCtl32 v6 chrome.", IDC_NFUI_ABOUT_BUILD, 14, 92, 290, 14
    DEFPUSHBUTTON "OK", IDOK, 256, 110, 50, 14
END

IDD_NFUI_PREFS DIALOGEX 0, 0, 240, 110
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Preferences"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "&Display name:", IDC_STATIC, 10, 10, 60, 12
    EDITTEXT IDC_NFUI_PREFS_NAME, 75, 8, 155, 14, ES_AUTOHSCROLL
    CONTROL "&Remember this session", IDC_NFUI_PREFS_REMEMBER, "Button",
            BS_AUTOCHECKBOX | WS_TABSTOP, 10, 32, 140, 12
    LTEXT "&Theme:", IDC_STATIC, 10, 52, 60, 12
    COMBOBOX IDC_NFUI_PREFS_THEME, 75, 50, 155, 60,
            CBS_DROPDOWNLIST | WS_TABSTOP
    DEFPUSHBUTTON "OK", IDOK, 130, 88, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 184, 88, 50, 14
END

IDT_NFUI_MAIN TOOLBAR 16, 16
BEGIN
    BUTTON IDM_NFUI_EXIT
END
